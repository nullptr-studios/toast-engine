<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="editor.App"
             xmlns:local="using:editor"
             xmlns:conv="using:editor.Converters"
             xmlns:vm="using:editor.Workspace"
             RequestedThemeVariant="Dark">

	<Application.Resources>
		<conv:SeverityToColorConverter x:Key="SeverityToColorConverter" />
		<conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
		<conv:EnabledToColorConverter x:Key="EnabledToColorConverter" />
	</Application.Resources>

	<Application.DataTemplates>
		<!-- Explicit templates take priority over ViewLocator — must be listed first -->
		<DataTemplate DataType="vm:HierarchyViewModel">
			<vm:Hierarchy />
		</DataTemplate>
		<DataTemplate DataType="vm:InspectorViewModel">
			<vm:Inspector />
		</DataTemplate>
		<DataTemplate DataType="vm:ViewportViewModel">
			<vm:Viewport />
		</DataTemplate>
		<local:ViewLocator />
	</Application.DataTemplates>

	<Application.Styles>
		<FluentTheme />
		<StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml" />
	</Application.Styles>
</Application>