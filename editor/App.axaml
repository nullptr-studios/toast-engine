<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="editor.App"
             xmlns:local="using:editor"
             xmlns:conv="using:editor.Converters"
             RequestedThemeVariant="Dark">

	<Application.Resources>
		<conv:SeverityToColorConverter x:Key="SeverityToColorConverter" />
		<conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
		<conv:EnabledToColorConverter x:Key="EnabledToColorConverter" />
	</Application.Resources>

	<Application.DataTemplates>
		<local:ViewLocator />
	</Application.DataTemplates>

	<Application.Styles>
		<FluentTheme />
		<DockFluentTheme />
	</Application.Styles>
</Application>
