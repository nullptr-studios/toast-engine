<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="editor.App"
             xmlns:local="using:editor"
             xmlns:conv="using:editor.Converters"
             RequestedThemeVariant="Dark">

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://editor/Resources/EditorColors.axaml" />
				<ResourceInclude Source="avares://editor/Resources/DragNumberBox.axaml" />
				<ResourceInclude Source="avares://editor/Resources/BoolBox.axaml" />
				<ResourceInclude Source="avares://editor/Resources/StringBox.axaml" />
				<ResourceInclude Source="avares://editor/Resources/ColorBox.axaml" />
			</ResourceDictionary.MergedDictionaries>
			<conv:SeverityToColorConverter x:Key="SeverityToColorConverter" />
			<conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
			<conv:EnabledToColorConverter x:Key="EnabledToColorConverter" />
			<conv:ScaleConverter x:Key="ScaleConverter" />
		</ResourceDictionary>
	</Application.Resources>

	<Application.DataTemplates>
		<local:ViewLocator />
	</Application.DataTemplates>

	<Application.Styles>
		<FluentTheme />
		<DockFluentTheme />
		<StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
	</Application.Styles>
</Application>