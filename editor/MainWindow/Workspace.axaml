<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:editor.MainWindow"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="editor.MainWindow.Workspace"
        x:DataType="vm:WorkspaceViewModel">

	<Grid ColumnDefinitions="300, *, 300">
		<vm:Hierarchy Grid.Column="0" DataContext="{Binding Hierarchy}"/>
		<vm:Viewport Grid.Column="1" DataContext="{Binding Viewport}"/>
		<vm:Inspector Grid.Column="2" DataContext="{Binding Inspector}"/>
	</Grid>
</UserControl>
