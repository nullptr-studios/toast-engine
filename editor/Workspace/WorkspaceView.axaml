<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:editor.Workspace"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="editor.Workspace.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel"
             Focusable="True"
             Background="{StaticResource Bg1}">

	<Panel>
		<Image Name="Surface" Stretch="Fill" />
		<Border Background="{StaticResource Bg2}" VerticalAlignment="Top"
		        Margin="4" Padding="8" CornerRadius="8">
			<StackPanel Orientation="Horizontal">
				<Button Content="Test" />
			</StackPanel>
		</Border>
	</Panel>
</UserControl>