<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:editor.Workspace"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             x:Class="editor.Workspace.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel"
             Focusable="True"
             Background="{StaticResource Bg2}"
             Padding="8">
	<DockPanel VerticalSpacing="8">
		<Grid DockPanel.Dock="Top"
		      ColumnDefinitions="Auto,8,Auto,Auto,Auto,Auto,*,Auto"
		      ColumnSpacing="4">
			<StackPanel Grid.Column="0"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="Select (Q)">
					<LucideIcon Kind="MousePointer2"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0"
				        ToolTip.Tip="Move (E)">
					<LucideIcon Kind="Move3d"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0"
				        ToolTip.Tip="Rotate (R)">
					<LucideIcon Kind="Rotate3d"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0"
				        ToolTip.Tip="Scale (T)">
					<LucideIcon Kind="Scale3d"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0"
				        ToolTip.Tip="Ruler (Y)">
					<LucideIcon Kind="Ruler"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>

			<StackPanel Grid.Column="2"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="World coordinates (F)">
					<LucideIcon Kind="Globe"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0"
				        ToolTip.Tip="Local coordinates (F)">
					<LucideIcon Kind="Box"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>

			<StackPanel Grid.Column="3"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="Grid snapping (G)">
					<StackPanel Orientation="Horizontal"
					            Spacing="8">
						<LucideIcon Kind="Grid2x2"
						            Size="18"
						            StrokeWidth="2.5" />
						<TextBlock Text=".10" />
					</StackPanel>
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0">
					<LucideIcon Kind="ChevronDown"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>
			<StackPanel Grid.Column="4"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="Rotate snapping (Shift+G)">
					<StackPanel Orientation="Horizontal"
					            Spacing="8">
						<LucideIcon Kind="RotateCw"
						            Size="18"
						            StrokeWidth="2.5" />
						<TextBlock Text="30" />
					</StackPanel>
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0">
					<LucideIcon Kind="ChevronDown"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>
			<StackPanel Grid.Column="5"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="Scale snapping (Alt+G)">
					<StackPanel Orientation="Horizontal"
					            Spacing="8">
						<LucideIcon Kind="Maximize2"
						            Size="18"
						            StrokeWidth="2.5" />
						<TextBlock Text=".10" />
					</StackPanel>
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0">
					<LucideIcon Kind="ChevronDown"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>

			<StackPanel Grid.Column="7"
			            Orientation="Horizontal">
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="6, 0, 0, 6"
				        ToolTip.Tip="Change viewport mode">
					<StackPanel Orientation="Horizontal"
					            Spacing="8">
						<LucideIcon Kind="Eclipse"
						            Size="18"
						            StrokeWidth="2.5" />
						<TextBlock Text="Mode" />
					</StackPanel>
				</Button>
				<Button Background="{StaticResource Bg3}"
				        CornerRadius="0, 6, 6, 0"
				        ToolTip.Tip="Toggle render layers visibility">
					<LucideIcon Kind="Eye"
					            Size="18"
					            StrokeWidth="2.5" />
				</Button>
			</StackPanel>
		</Grid>
		<Panel x:Name="ViewportPanel">
			<Border CornerRadius="8"
			        ClipToBounds="True">
				<Image Name="Surface"
				       Stretch="Uniform" />
			</Border>
		</Panel>
	</DockPanel>
</UserControl>