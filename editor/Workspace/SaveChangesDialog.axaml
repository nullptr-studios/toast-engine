<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="editor.Workspace.SaveChangesDialog"
        Title="Unsaved Changes"
        Width="420" Height="150"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#202020">

	<Window.Styles>
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#0078d4" />
			<Setter Property="Foreground" Value="White" />
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="*,Auto" Margin="16" RowSpacing="16">
		<TextBlock Grid.Row="0" x:Name="MessageText"
		           TextWrapping="Wrap"
		           VerticalAlignment="Center"
		           Foreground="#cccccc" />

		<StackPanel Grid.Row="1" Orientation="Horizontal"
		            HorizontalAlignment="Right" Spacing="8">
			<Button Content="Cancel" Click="OnCancel" Width="90" />
			<Button Content="Don't Save" Click="OnDontSave" Width="90" />
			<Button Content="Save" Classes="primary" Click="OnSave" Width="90" />
		</StackPanel>
	</Grid>
</Window>
