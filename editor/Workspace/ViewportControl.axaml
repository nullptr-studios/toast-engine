<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="editor.Workspace.ViewportControl"
             Focusable="True">
	<Panel>
		<Border CornerRadius="8"
		        ClipToBounds="True"
		        Background="{StaticResource Bg1}">
			<Image Name="Surface"
			       Stretch="Uniform" />
		</Border>
		<!-- capture hint -->
		<Border Name="FocusHint"
		        HorizontalAlignment="Center"
		        VerticalAlignment="Top"
		        Margin="0, 12, 0, 0"
		        Background="{StaticResource Bg3}"
		        CornerRadius="6"
		        Padding="12, 6"
		        IsVisible="False">
			<TextBlock Text="Press ` to loose focus"
			           Foreground="{StaticResource Text}" />
		</Border>
	</Panel>
</UserControl>