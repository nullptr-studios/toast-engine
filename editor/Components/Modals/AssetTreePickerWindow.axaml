<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:editor.Components.Modals"
        x:Class="editor.Components.Modals.AssetTreePickerWindow"
        x:DataType="local:AssetTreePickerViewModel"
        Title="Select Destination Folder"
        Width="380" Height="460"
        CanResize="False" CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource E2}">

	<Grid RowDefinitions="*,Auto" Margin="12" RowSpacing="8">
		<Border Grid.Row="0" Background="{StaticResource E1}" CornerRadius="8">
			<TreeView ItemsSource="{Binding Roots}"
			          SelectedItem="{Binding SelectedFolder}"
			          Margin="4">
				<TreeView.ItemTemplate>
					<TreeDataTemplate ItemsSource="{Binding (local:AssetFolderNode).Children}">
						<TextBlock Text="{Binding Name}" Margin="4,2" />
					</TreeDataTemplate>
				</TreeView.ItemTemplate>
				<TreeView.Styles>
					<Style Selector="TreeViewItem" x:DataType="local:AssetFolderNode">
						<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
					</Style>
				</TreeView.Styles>
			</TreeView>
		</Border>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
			<Button Content="Cancel" Click="OnCancel" Width="80" />
			<Button Content="Select" Click="OnConfirm" Width="80"
			        IsEnabled="{Binding SelectedFolder, Converter={x:Static ObjectConverters.IsNotNull}}" />
		</StackPanel>
	</Grid>
</Window>