<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:editor.Components.Modals"
        x:Class="editor.Components.Modals.SaveFileModal"
        x:DataType="local:SaveFileViewModel"
        Title="Save Workspace"
        Width="480" Height="150"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource E2}">

	<Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12" RowSpacing="8">
		<TextBlock Grid.Row="0" Text="Save location" Foreground="{StaticResource Fg}" />

		<Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
			<TextBox Grid.Column="0" Text="{Binding Path}" PlaceholderText="assets://name.tnode" />
			<Button Grid.Column="1" Content="..." Width="40" Click="OnBrowse" />
		</Grid>

		<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
			<Button Content="Cancel" Click="OnCancel" Width="80" />
			<Button Content="Save" Click="OnConfirm" Width="80" />
		</StackPanel>
	</Grid>
</Window>