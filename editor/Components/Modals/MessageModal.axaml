<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lucide="using:Lucide.Avalonia"
        xmlns:local="clr-namespace:editor.Components.Modals"
        x:Class="editor.Components.Modals.MessageModal"
        x:DataType="local:MessageModalViewModel"
        SizeToContent="Height"
        Width="420"
        MinWidth="320"
        MaxWidth="600"
        CanResize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Bg3}"
        Title="{Binding Title}">

	<Design.DataContext>
		<local:MessageModalViewModel />
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="Button.primary">
			<Setter Property="Background"
			        Value="{StaticResource Red}" />
			<Setter Property="Foreground"
			        Value="White" />
			<Setter Property="MinWidth"
			        Value="80" />
		</Style>
	</Window.Styles>

	<StackPanel Margin="24"
	            Spacing="16">
		<StackPanel Orientation="Horizontal"
		            Spacing="12">
			<lucide:LucideIcon Size="32"
			                   StrokeWidth="2.5"
			                   IsVisible="{Binding ShowIcon}"
			                   Kind="{Binding IconKind}"
			                   Foreground="{Binding IconColor}" />
			<TextBlock Text="{Binding Title}"
			           FontSize="16"
			           FontWeight="SemiBold"
			           VerticalAlignment="Center" />
		</StackPanel>

		<TextBlock Text="{Binding Message}"
		           TextWrapping="Wrap"
		           Foreground="{StaticResource Text}" />

		<Grid ColumnDefinitions="auto, *, auto, auto"
		      ColumnSpacing="8"
		      Margin="0,8,0,0">
			<Button Grid.Column="0"
			        MinWidth="80"
			        IsVisible="{Binding ShowCancel}"
			        Click="OnCancel"
			        HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal">
					<LucideIcon Size="16"
					            StrokeWidth="2.5"
					            Margin="0,0,4,0"
					            IsVisible="{Binding HasCancelIcon}"
					            Kind="{Binding CancelIcon}" />
					<TextBlock Text="{Binding CancelLabel}" />
				</StackPanel>
			</Button>
			<Button Grid.Column="2"
			        IsVisible="{Binding ShowNo}"
			        Click="OnNo"
			        HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal">
					<LucideIcon Size="16"
					            StrokeWidth="2.5"
					            Margin="0,0,4,0"
					            IsVisible="{Binding HasNoIcon}"
					            Kind="{Binding NoIcon}" />
					<TextBlock Text="{Binding NoLabel}" />
				</StackPanel>
			</Button>
			<Button Grid.Column="3"
			        Classes="primary"
			        Click="OnOk"
			        HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal">
					<LucideIcon Size="16"
					            StrokeWidth="2.5"
					            Margin="0,0,4,0"
					            IsVisible="{Binding HasOkIcon}"
					            Kind="{Binding OkIcon}" />
					<TextBlock Text="{Binding OkLabel}" />
				</StackPanel>
			</Button>
		</Grid>
	</StackPanel>
</Window>