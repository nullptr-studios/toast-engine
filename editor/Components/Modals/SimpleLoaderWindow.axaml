<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:editor.Components.Modals"
        x:Class="editor.Components.Modals.SimpleLoaderWindow"
        x:DataType="local:LoaderViewModel"
        Title="Processing..."
        Width="640" Height="400"
        CanResize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg2}">

	<Design.DataContext>
		<local:LoaderViewModel />
	</Design.DataContext>

	<Border Background="{StaticResource Bg2}" Padding="8">
		<Grid RowDefinitions="*,Auto" Background="{StaticResource Bg2}" RowSpacing="8">
			<Border Grid.Row="0" CornerRadius="8, 8, 0, 0" Background="{StaticResource Bg1}" Padding="8">
				<ScrollViewer x:Name="ConsoleScroll">
					<ItemsControl ItemsSource="{Binding ConsoleLines}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<SelectableTextBlock Text="{Binding}"
								                     FontFamily="FiraCode Nerd Font,Consolas,monospace"
								                     FontSize="13"
								                     Foreground="{StaticResource TextMuted}"
								                     TextWrapping="Wrap"
								                     Margin="12,2" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Border>

			<Border Grid.Row="1" Padding="0,-8,0,0">
				<ProgressBar Value="{Binding Progress}"
				             Minimum="0" Maximum="100" Height="20"
				             CornerRadius="0,0,8,8"
				             Foreground="{StaticResource Red}"
				             Background="{StaticResource Bg1}"/>
			</Border>
		</Grid>
	</Border>
</Window>