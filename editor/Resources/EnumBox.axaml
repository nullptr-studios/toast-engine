<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:elements="clr-namespace:editor.Components.Elements"
                    xmlns:lucide="using:Lucide.Avalonia">

	<Design.PreviewWith>
		<Border Padding="8" Background="{StaticResource Bg3}" Width="200">
			<StackPanel Spacing="8">
				<elements:EnumBox Value="float"  />
				<elements:EnumBox Value="string" IsEnabled="False" />
			</StackPanel>
		</Border>
	</Design.PreviewWith>

	<ControlTheme x:Key="{x:Type elements:EnumBox}" TargetType="elements:EnumBox">
		<Setter Property="FontFamily" Value="FiraCode Nerd Font,Consolas,monospace" />
		<Setter Property="FontSize" Value="15" />
		<Setter Property="MinHeight" Value="34" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="CornerRadius" Value="6" />
		<Setter Property="Cursor" Value="Hand" />

		<Setter Property="Template">
			<ControlTemplate>
				<Panel>
					<Border x:Name="PART_Root"
					        CornerRadius="{TemplateBinding CornerRadius}"
					        Padding="8,4">
						<Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
							<TextBlock x:Name="PART_Display"
							           Text="{TemplateBinding Value}"
							           VerticalAlignment="Center"
							           TextTrimming="CharacterEllipsis" />
							<lucide:LucideIcon Grid.Column="1"
							                   Kind="ChevronDown" Size="14" StrokeWidth="2"
							                   Foreground="{StaticResource TextMuted}"
							                   VerticalAlignment="Center" />
						</Grid>
					</Border>

					<Popup x:Name="PART_Popup"
					       IsLightDismissEnabled="True"
					       PlacementTarget="{TemplateBinding}"
					       Placement="Bottom"
					       MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
						<Border Background="{StaticResource Bg3}"
						        CornerRadius="6"
						        Padding="4"
						        BorderBrush="{StaticResource Bg4}"
						        BorderThickness="1">
							<ItemsControl x:Name="PART_List">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<StackPanel Spacing="2" />
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
							</ItemsControl>
						</Border>
					</Popup>
				</Panel>
			</ControlTemplate>
		</Setter>

		<!-- Default colors -->
		<Style Selector="^ /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg1}" />
		</Style>
		<Style Selector="^ /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource Text}" />
		</Style>

		<!-- Hover -->
		<Style Selector="^:pointerover /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg2}" />
		</Style>

		<!-- Disabled -->
		<Style Selector="^:disabled /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg2}" />
		</Style>
		<Style Selector="^:disabled /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource TextMuted}" />
		</Style>
	</ControlTheme>

</ResourceDictionary>
