<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:elements="clr-namespace:editor.Components.Elements"
                    xmlns:lucide="using:Lucide.Avalonia">

	<Design.PreviewWith>
		<Border Padding="8"
		        Background="{StaticResource Bg3}"
		        Width="220">
			<elements:ArrayBox>
				<elements:ArrayBox.ItemTemplate>
					<DataTemplate>
						<elements:StringBox Value="Item" />
					</DataTemplate>
				</elements:ArrayBox.ItemTemplate>
			</elements:ArrayBox>
		</Border>
	</Design.PreviewWith>

	<ControlTheme x:Key="{x:Type elements:ArrayBox}"
	              TargetType="elements:ArrayBox">
		<Setter Property="HorizontalAlignment"
		        Value="Stretch" />
		<Setter Property="CornerRadius"
		        Value="6" />
		<Setter Property="Background"
		        Value="{StaticResource Bg1}" />
		<Setter Property="Padding"
		        Value="6" />

		<Setter Property="Template">
			<ControlTemplate>
				<Border x:Name="PART_Root"
				        Background="{TemplateBinding Background}"
				        CornerRadius="{TemplateBinding CornerRadius}"
				        Padding="{TemplateBinding Padding}">
					<StackPanel Spacing="6">
						<ItemsControl x:Name="PART_Items" />

						<Button x:Name="PART_Add"
						        HorizontalAlignment="Stretch"
						        HorizontalContentAlignment="Center"
						        BorderThickness="0"
						        Padding="6"
						        CornerRadius="6"
						        Cursor="Hand">
							<Button.Resources>
								<SolidColorBrush x:Key="ButtonBackground"
								                 Color="#303030" />
								<SolidColorBrush x:Key="ButtonBackgroundPointerOver"
								                 Color="#404040" />
								<SolidColorBrush x:Key="ButtonBackgroundPressed"
								                 Color="#404040" />
								<SolidColorBrush x:Key="ButtonForeground"
								                 Color="#a0a0a0" />
								<SolidColorBrush x:Key="ButtonForegroundPointerOver"
								                 Color="#fafafa" />
								<SolidColorBrush x:Key="ButtonForegroundPressed"
								                 Color="#fafafa" />
							</Button.Resources>
							<StackPanel Orientation="Horizontal"
							            Spacing="6">
								<lucide:LucideIcon Kind="Plus"
								                   Size="14"
								                   StrokeWidth="2.5" />
								<TextBlock Text="{TemplateBinding AddLabel}"
								           VerticalAlignment="Center" />
							</StackPanel>
						</Button>
					</StackPanel>
				</Border>
			</ControlTemplate>
		</Setter>

		<!-- Disabled -->
		<Style Selector="^:disabled /template/ Border#PART_Root">
			<Setter Property="Opacity"
			        Value="0.6" />
		</Style>
	</ControlTheme>

</ResourceDictionary>