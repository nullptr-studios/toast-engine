<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lucide="using:Lucide.Avalonia"
                    xmlns:elements="clr-namespace:editor.Components.Elements">

	<Design.PreviewWith>
		<Border Padding="8" Background="{StaticResource Bg3}">
			<StackPanel Spacing="8" MinWidth="150" MaxWidth="200">
				<elements:NodeBox NodeType="Node" />
				<elements:NodeBox NodeType="Camera" IsEnabled="False" />
			</StackPanel>
		</Border>
	</Design.PreviewWith>

	<ControlTheme x:Key="{x:Type elements:NodeBox}" TargetType="elements:NodeBox">
		<Setter Property="FontFamily" Value="FiraCode Nerd Font,Consolas,monospace" />
		<Setter Property="FontSize" Value="15" />
		<Setter Property="MinHeight" Value="34" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="CornerRadius" Value="6" />

		<Setter Property="Template">
			<ControlTemplate>
				<Border x:Name="PART_Root" CornerRadius="{TemplateBinding CornerRadius}">
					<Panel>
						<Grid ColumnDefinitions="*,Auto">
							<!-- Data side -->
							<DockPanel Grid.Column="0" LastChildFill="True" Margin="8" VerticalAlignment="Center">
								<Border x:Name="PART_Icon"
								        DockPanel.Dock="Left"
								        Width="16" Height="16"
								        CornerRadius="4"
								        Margin="0,0,8,0"
								        VerticalAlignment="Center"
								        Background="DeepPink"
								        IsVisible="{TemplateBinding HasNode}" />

								<TextBlock x:Name="PART_Display"
								           Text="{TemplateBinding DisplayName}"
								           TextTrimming="CharacterEllipsis"
								           VerticalAlignment="Center" />
							</DockPanel>

							<!-- Picker button -->
							<Border x:Name="PART_Button"
							        Grid.Column="1"
							        Background="{StaticResource Bg4}"
							        CornerRadius="0,6,6,0"
							        Padding="8"
							        VerticalAlignment="Stretch">
								<lucide:LucideIcon Kind="ListTree" Size="16"
								                   VerticalAlignment="Center" HorizontalAlignment="Center"
								                   Foreground="{StaticResource Text}" />
							</Border>
						</Grid>

						<!-- broken reference: red stroke drawn inwards, overlaid so it never grows the box -->
						<Border BorderBrush="{StaticResource Red}"
						        BorderThickness="2"
						        CornerRadius="{TemplateBinding CornerRadius}"
						        IsHitTestVisible="False"
						        IsVisible="{TemplateBinding IsMissing}" />
					</Panel>
				</Border>
			</ControlTemplate>
		</Setter>

		<!-- Default colors -->
		<Style Selector="^ /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg1}" />
		</Style>

		<!-- Resolved: node name in Text color, upright -->
		<Style Selector="^[HasNode=True] /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource Text}" />
			<Setter Property="FontStyle" Value="Normal" />
		</Style>
		<!-- Empty / missing: muted and italic, "(Type)" placeholder -->
		<Style Selector="^[HasNode=False] /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource TextMuted}" />
			<Setter Property="FontStyle" Value="Italic" />
		</Style>

		<!-- Hover affordance: underline the name itself (only below the text), when removable -->
		<Style Selector="^[HasNode=True] /template/ TextBlock#PART_Display:pointerover">
			<Setter Property="TextDecorations" Value="Underline" />
		</Style>

		<!-- Hover on picker button -->
		<Style Selector="^ /template/ Border#PART_Button:pointerover">
			<Setter Property="Background" Value="{StaticResource Bg5}" />
		</Style>

		<!-- Disabled (read-only) colors -->
		<Style Selector="^:disabled /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg2}" />
		</Style>
		<Style Selector="^:disabled /template/ Border#PART_Button">
			<Setter Property="Background" Value="{StaticResource Bg2}" />
		</Style>
		<Style Selector="^:disabled /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource TextMuted}" />
		</Style>
	</ControlTheme>

</ResourceDictionary>
