<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:elements="clr-namespace:editor.Components.Elements">

	<Design.PreviewWith>
		<Border Padding="8" Background="{StaticResource Bg3}">
			<StackPanel Spacing="8" MinWidth="150" MaxWidth="200">
				<elements:StringBox Value="Short" />
				<elements:StringBox Value="The quick brown fox jumps over the lazy dog" />
				<elements:StringBox Value="No wrap, this stays on one line" Wrap="False" />
				<elements:StringBox Value="Disabled" IsEnabled="False" />
			</StackPanel>
		</Border>
	</Design.PreviewWith>

	<ControlTheme x:Key="{x:Type elements:StringBox}" TargetType="elements:StringBox">
		<Setter Property="FontFamily" Value="FiraCode Nerd Font,Consolas,monospace" />
		<Setter Property="FontSize" Value="15" />
		<Setter Property="MinHeight" Value="34" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="CornerRadius" Value="6" />

		<Setter Property="Template">
			<ControlTemplate>
				<Border x:Name="PART_Root" CornerRadius="{TemplateBinding CornerRadius}" Padding="8,8">
					<Panel>
						<TextBlock x:Name="PART_Display"
						           Text="{TemplateBinding Value}"
						           TextWrapping="{TemplateBinding WrapMode}"
						           VerticalAlignment="Center" />

						<TextBox x:Name="PART_Editor"
						         IsVisible="{TemplateBinding IsEditing}"
						         Background="{StaticResource Bg1}"
						         Foreground="{StaticResource Text}"
						         BorderThickness="0"
						         Padding="8"
						         Margin="-8"
						         MinHeight="0"
						         TextWrapping="{TemplateBinding WrapMode}"
						         AcceptsReturn="True"
						         VerticalContentAlignment="Top"
						         HorizontalContentAlignment="Left" />
					</Panel>
				</Border>
			</ControlTemplate>
		</Setter>

		<!-- Default colors -->
		<Style Selector="^ /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg1}" />
		</Style>
		<Style Selector="^ /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource Text}" />
		</Style>

		<!-- Disabled colors -->
		<Style Selector="^:disabled /template/ Border#PART_Root">
			<Setter Property="Background" Value="{StaticResource Bg2}" />
		</Style>
		<Style Selector="^:disabled /template/ TextBlock#PART_Display">
			<Setter Property="Foreground" Value="{StaticResource TextMuted}" />
		</Style>
	</ControlTheme>

</ResourceDictionary>
