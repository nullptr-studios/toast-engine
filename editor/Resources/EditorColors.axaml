<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Background levels, E1 = darkest, E5 = lightest -->
	<SolidColorBrush x:Key="Bg1" Color="#101010" />
	<SolidColorBrush x:Key="Bg2" Color="#202020" />
	<SolidColorBrush x:Key="Bg3" Color="#303030" />
	<SolidColorBrush x:Key="Bg4" Color="#404040" />
	<SolidColorBrush x:Key="Bg5" Color="#505050" />

	<!-- Text -->
	<SolidColorBrush x:Key="Text" Color="#fafafa" />
	<SolidColorBrush x:Key="TextMuted" Color="#a0a0a0" />

	<!-- Semantic accent colors -->
	<SolidColorBrush x:Key="Red" Color="#ff004d" />
	<SolidColorBrush x:Key="Green" Color="#00cc33" />
	<SolidColorBrush x:Key="Blue" Color="#29adff" />
	<SolidColorBrush x:Key="Magenta" Color="#ad73ff" />
	<SolidColorBrush x:Key="Orange" Color="#ffa300" />
	<SolidColorBrush x:Key="Yellow" Color="#ffec27" />
	<SolidColorBrush x:Key="Cyan" Color="#73ffea" />
	<SolidColorBrush x:Key="Beige" Color="#ffccaa" />

</ResourceDictionary>