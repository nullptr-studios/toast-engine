<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lucide="using:Lucide.Avalonia"
        xmlns:local="clr-namespace:editor.Services"
        x:Class="editor.Services.ModalPopupWindow"
        x:DataType="local:ModalPopupViewModel"
        SizeToContent="Height"
        Width="420"
        MinWidth="320"
        MaxWidth="600"
        CanResize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1e1e1e"
        Title="{Binding Title}">

	<Design.DataContext>
		<local:ModalPopupViewModel />
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#0078d4" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="MinWidth" Value="80" />
		</Style>
	</Window.Styles>

	<StackPanel Margin="24" Spacing="16">
		<!-- Icon + Title row -->
		<StackPanel Orientation="Horizontal" Spacing="12">
			<lucide:LucideIcon x:Name="SeverityIcon"
			                   Width="24" Height="24"
			                   Kind="{Binding IconKind}"
			                   Foreground="{Binding IconColor}" />
			<TextBlock Text="{Binding Title}"
			           FontSize="16" FontWeight="SemiBold"
			           VerticalAlignment="Center" />
		</StackPanel>

		<!-- Message -->
		<TextBlock Text="{Binding Message}"
		           TextWrapping="Wrap"
		           Foreground="#cccccc"
		           Margin="36,0,0,0" />

		<!-- Buttons -->
		<StackPanel Orientation="Horizontal"
		            HorizontalAlignment="Right"
		            Spacing="8"
		            Margin="0,8,0,0">
			<Button Content="Cancel"
			        IsVisible="{Binding ShowCancel}"
			        Click="OnCancel" />
			<Button Content="OK"
			        Classes="primary"
			        Click="OnOk" />
		</StackPanel>
	</StackPanel>
</Window>