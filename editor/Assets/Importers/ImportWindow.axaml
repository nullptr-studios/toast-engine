<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:editor.Assets.Importers"
        xmlns:lucide="using:Lucide.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="900"
        Height="900" Width="800"
        MinHeight="600"
        CanResize="True"
        CanMaximize="False"
        x:Class="editor.Assets.Importers.ImportWindow"
        x:DataType="local:ImportWindowViewModel"
        Title="Import"
        Background="{StaticResource E2}">

	<Window.Styles>
		<Style Selector="Button.TreeViewRow">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="Transparent" />
			</Style>
			<Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="Transparent" />
			</Style>
		</Style>
		<Style Selector="TextBlock.SettingLabel">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Foreground" Value="{StaticResource FgMuted}" />
		</Style>
	</Window.Styles>

	<Grid ColumnDefinitions="Auto, *" Margin="12" ColumnSpacing="8">
		<!-- Tree view column -->
		<Border Grid.Column="0" Background="{StaticResource E1}" CornerRadius="8">
			<DockPanel Margin="8" MinWidth="360">
				<TextBox DockPanel.Dock="Bottom"
				         Text="{Binding SearchText}"
				         PlaceholderText="Search artwork..."
				         Margin="0,4,0,0" />

				<TreeView ItemsSource="{Binding ImportNodes}">
					<TreeView.ItemTemplate>
						<TreeDataTemplate ItemsSource="{Binding (local:ImportFolderViewModel).Children}">
							<Button Command="{Binding ToggleSelection}"
							        Classes="TreeViewRow"
							        IsVisible="{Binding IsVisible}">
								<StackPanel Orientation="Horizontal"
								            Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacityConverter}}">
									<CheckBox IsChecked="{Binding IsSelected}"
									          IsThreeState="True"
									          IsEnabled="{Binding !IsReadOnly}"
									          IsHitTestVisible="False"
									          VerticalAlignment="Center" />
									<TextBlock Text="{Binding Name}"
									           VerticalAlignment="Center"
									           Margin="4,0,0,0"
									           Foreground="{Binding IsEnabled, Converter={StaticResource EnabledToColorConverter}}" />
								</StackPanel>
							</Button>
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
					<TreeView.Styles>
						<Style Selector="TreeViewItem" x:DataType="local:ImportNodeViewModel">
							<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
							<Setter Property="IsVisible" Value="{Binding IsVisible}" />
							<Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
								<Setter Property="Background" Value="Transparent" />
							</Style>
							<Style Selector="^:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
								<Setter Property="Background" Value="Transparent" />
							</Style>
						</Style>
					</TreeView.Styles>
				</TreeView>
			</DockPanel>
		</Border>

		<!-- Settings column -->
		<DockPanel Grid.Column="1">

			<!-- Location row -->
			<StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
				<TextBlock Text="Location" Foreground="#b0b0b0" />
				<Grid ColumnDefinitions="*, Auto">
					<TextBox Grid.Column="0"
					         Text="{Binding LocationPath}"
					         CornerRadius="4,0,0,4" />
					<Button Grid.Column="1"
					        Command="{Binding BrowseLocationCommand}"
					        ToolTip.Tip="Browse assets folder"
					        CornerRadius="0,4,4,0"
					        Padding="8,4">
						<lucide:LucideIcon Kind="FolderOpen" Size="16" />
					</Button>
				</Grid>
			</StackPanel>

			<!-- Bottom buttons -->
			<StackPanel DockPanel.Dock="Bottom"
			            Orientation="Horizontal"
			            HorizontalAlignment="Right"
			            Spacing="8"
			            Margin="0,8,0,0">
				<Button Command="{Binding CancelCommand}">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<lucide:LucideIcon Kind="X" Size="14" />
						<TextBlock Text="Cancel" />
					</StackPanel>
				</Button>
				<Button Background="{StaticResource Green}" Command="{Binding ImportCommand}">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<lucide:LucideIcon Kind="PackageCheck" Size="14" />
						<TextBlock Text="Import" />
					</StackPanel>
				</Button>
			</StackPanel>

			<!-- Asset type settings tree -->
			<TreeView>
				<TreeViewItem Header="Textures" IsExpanded="True">
					<StackPanel Margin="8,6" Spacing="8"
					            x:DataType="local:ImportWindowViewModel">
						<CheckBox Content="Generate Mipmaps"
						          IsChecked="{Binding TextureSettings.GenerateMipmaps}" />

						<Grid ColumnDefinitions="130, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
						      RowSpacing="6" ColumnSpacing="12">

							<TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Max Resolution" />
							<ComboBox Grid.Row="0" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllMaxResolutions}"
							          SelectedItem="{Binding TextureSettings.MaxResolution}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Compression" />
							<ComboBox Grid.Row="1" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllCompressions}"
							          SelectedItem="{Binding TextureSettings.Compression}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="2" Grid.Column="0" Classes="SettingLabel" Text="Super Compression" />
							<ComboBox Grid.Row="2" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllSuperCompressions}"
							          SelectedItem="{Binding TextureSettings.SuperCompression}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="3" Grid.Column="0" Classes="SettingLabel" Text="Address U" />
							<ComboBox Grid.Row="3" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllAddressModes}"
							          SelectedItem="{Binding TextureSettings.AddressU}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="4" Grid.Column="0" Classes="SettingLabel" Text="Address V" />
							<ComboBox Grid.Row="4" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllAddressModes}"
							          SelectedItem="{Binding TextureSettings.AddressV}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="5" Grid.Column="0" Classes="SettingLabel" Text="Filter" />
							<ComboBox Grid.Row="5" Grid.Column="1"
							          ItemsSource="{x:Static local:TextureImporter+Settings.AllFilterModes}"
							          SelectedItem="{Binding TextureSettings.Filter}"
							          HorizontalAlignment="Stretch" />

							<TextBlock Grid.Row="6" Grid.Column="0" Classes="SettingLabel" Text="Anisotropy" />
							<NumericUpDown Grid.Row="6" Grid.Column="1"
							               Value="{Binding TextureSettings.Anisotropy}"
							               Minimum="1" Maximum="16" Increment="1"
							               FormatString="0.0"
							               HorizontalAlignment="Stretch" />
						</Grid>
					</StackPanel>
				</TreeViewItem>

				<TreeViewItem Header="GLTF" IsEnabled="False">
					<TextBlock Text="Not yet supported" Margin="8" Foreground="{StaticResource E5}" />
				</TreeViewItem>

				<TreeViewItem Header="PSD">
					<StackPanel Margin="8,6" Spacing="8" x:DataType="local:ImportWindowViewModel">
						<CheckBox Content="Create subfolder" IsChecked="{Binding PsdSettings.CreateFolder}" />

						<Grid ColumnDefinitions="130, *" RowDefinitions="Auto"
						      RowSpacing="6" ColumnSpacing="1">
							<TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Mode" />
							<ComboBox Grid.Row="0" Grid.Column="1"
							          ItemsSource="{x:Static local:PsdImporter+Settings.AllImportModes}"
							          SelectedItem="{Binding PsdSettings.ImportMode}"
							          HorizontalAlignment="Stretch" />
						</Grid>
					</StackPanel>
				</TreeViewItem>
			</TreeView>
		</DockPanel>
	</Grid>
</Window>