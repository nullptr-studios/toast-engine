<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:editor.Editors"
             xmlns:elements="using:editor.Components.Elements"
             xmlns:cc="using:editor.Components.CurveCanvas"
             xmlns:lucide="using:Lucide.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1800" d:DesignHeight="400"
             x:Class="editor.Editors.HapticsView"
             x:DataType="vm:HapticsViewModel"
             Background="{StaticResource Bg2}"
             Padding="8">

	<UserControl.KeyBindings>
		<KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
	</UserControl.KeyBindings>

	<UserControl.Styles>
		<Style Selector="TextBlock.lbl">
			<Setter Property="Foreground" Value="{StaticResource TextMuted}" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="TextTrimming" Value="CharacterEllipsis" />
		</Style>
		<Style Selector="Button.icon-btn">
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="5" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Border.point-row">
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="4" />
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Border.point-row.selected">
			<Setter Property="Background" Value="{StaticResource Bg4}" />
		</Style>
	</UserControl.Styles>

	<Design.DataContext>
		<vm:HapticsViewModel />
	</Design.DataContext>

	<Panel>

		<!-- Editor -->
		<Grid ColumnDefinitions="260,8,*" IsVisible="{Binding HasContent}">

			<!-- Left panel -->
			<Border Grid.Column="0" Background="{StaticResource Bg3}" CornerRadius="8" Padding="8">
				<DockPanel VerticalSpacing="8">

					<!-- Header -->
					<DockPanel DockPanel.Dock="Top">
						<Button DockPanel.Dock="Right" Classes="icon-btn"
						        Command="{Binding SaveCommand}"
						        Background="{StaticResource Red}"
						        ToolTip.Tip="Save (Ctrl+S)">
							<lucide:LucideIcon Kind="Save" Size="16" StrokeWidth="2.5" />
						</Button>
						<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
							<lucide:LucideIcon Kind="Vibrate" Size="16" StrokeWidth="2.5"
							                   Foreground="{StaticResource TextMuted}" />
							<TextBlock Text="{Binding DisplayTitle}" FontWeight="Bold"
							           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
						</StackPanel>
					</DockPanel>

					<!-- Unsupported-mode banner -->
					<Border DockPanel.Dock="Top" Background="{StaticResource DarkYellow}"
					        CornerRadius="6" Padding="8,6"
					        IsVisible="{Binding UnsupportedMode}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<lucide:LucideIcon Kind="Lock" Size="13" StrokeWidth="2.5" />
							<TextBlock Text="Mode not supported yet — read-only" FontSize="13"
							           VerticalAlignment="Center" />
						</StackPanel>
					</Border>

					<ScrollViewer HorizontalScrollBarVisibility="Disabled">
						<StackPanel Spacing="8" IsEnabled="{Binding InputsEnabled}">

							<!-- Common properties -->
							<Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto"
							      RowSpacing="6" ColumnSpacing="8">
								<TextBlock Classes="lbl" Text="Mode" />
								<elements:EnumBox Grid.Column="1"
								                  Value="{Binding ModeName, Mode=TwoWay}"
								                  Options="{x:Static vm:HapticsViewModel.ModeNames}" />
								<TextBlock Grid.Row="1" Classes="lbl" Text="Priority" />
								<elements:DragIntBox Grid.Row="1" Grid.Column="1"
								                     Value="{Binding Priority, Mode=TwoWay}" />
								<TextBlock Grid.Row="2" Classes="lbl" Text="Duration" />
								<elements:DragIntBox Grid.Row="2" Grid.Column="1"
								                     Value="{Binding DurationMs, Mode=TwoWay}"
								                     Minimum="0" Unit="ms" />
							</Grid>

							<!-- Standard mode -->
							<Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto"
							      RowSpacing="6" ColumnSpacing="8"
							      IsVisible="{Binding IsStandardMode}">
								<TextBlock Classes="lbl" Text="Left" />
								<elements:DragFloatBox Grid.Column="1"
								                       Value="{Binding Left, Mode=TwoWay}"
								                       Minimum="0" Maximum="1" />
								<TextBlock Grid.Row="1" Classes="lbl" Text="Right" />
								<elements:DragFloatBox Grid.Row="1" Grid.Column="1"
								                       Value="{Binding Right, Mode=TwoWay}"
								                       Minimum="0" Maximum="1" />
							</Grid>

							<!-- Curve mode -->
							<StackPanel Spacing="8" IsVisible="{Binding IsCurveMode}">
								<Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
								      RowSpacing="6" ColumnSpacing="8">
									<TextBlock Classes="lbl" Text="Channels" />
									<elements:EnumBox Grid.Column="1"
									                  Value="{Binding ChannelsName, Mode=TwoWay}"
									                  Options="{x:Static vm:HapticsViewModel.ChannelNames}" />
									<TextBlock Grid.Row="1" Classes="lbl" Text="Pan"
									           IsVisible="{Binding IsSingleChannel}" />
									<elements:DragFloatBox Grid.Row="1" Grid.Column="1"
									                       Value="{Binding Pan, Mode=TwoWay}"
									                       Minimum="-1" Maximum="1"
									                       IsVisible="{Binding IsSingleChannel}" />
									<TextBlock Grid.Row="2" Classes="lbl" Text="Multiplier" />
									<elements:DragFloatBox Grid.Row="2" Grid.Column="1"
									                       Value="{Binding Multiplier, Mode=TwoWay}"
									                       Minimum="0" />
									<TextBlock Grid.Row="3" Classes="lbl" Text="Editing"
									           IsVisible="{Binding IsDualChannel}" />
									<elements:EnumBox Grid.Row="3" Grid.Column="1"
									                  Value="{Binding EditTargetName, Mode=TwoWay}"
									                  Options="{x:Static vm:HapticsViewModel.EditTargetNames}"
									                  IsVisible="{Binding IsDualChannel}" />
									<TextBlock Grid.Row="4" Classes="lbl" Text="Spline" />
									<elements:EnumBox Grid.Row="4" Grid.Column="1"
									                  Value="{Binding CurveSplineTypeName, Mode=TwoWay}"
									                  Options="{x:Static vm:CurveViewModel.SplineTypeNames}" />
								</Grid>

								<!-- Bezier hint -->
								<TextBlock Classes="lbl" Text="{Binding BezierHint}"
								           FontSize="12" TextWrapping="Wrap"
								           IsVisible="{Binding HasBezierHint}" />

								<!-- Points header -->
								<DockPanel>
									<Button DockPanel.Dock="Right" Classes="icon-btn"
									        Command="{Binding AddPointCommand}"
									        ToolTip.Tip="Add point">
										<lucide:LucideIcon Kind="Plus" Size="14" StrokeWidth="2.5"
										                   Foreground="{StaticResource TextMuted}" />
									</Button>
									<TextBlock Text="Points" FontWeight="SemiBold" VerticalAlignment="Center" />
								</DockPanel>

								<!-- Point list -->
								<ItemsControl ItemsSource="{Binding PointRows}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Spacing="2" />
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:CurvePointVM">
											<Border Classes="point-row" Classes.selected="{Binding IsSelected}">
												<Grid ColumnDefinitions="24,*,*,30" ColumnSpacing="4">
													<TextBlock Classes="lbl" Text="{Binding Label}" FontSize="12"
													           HorizontalAlignment="Center" />
													<elements:DragFloatBox Grid.Column="1"
													                       Value="{Binding X, Mode=TwoWay}"
													                       Minimum="0" Maximum="1" />
													<elements:DragFloatBox Grid.Column="2"
													                       Value="{Binding Y, Mode=TwoWay}"
													                       Minimum="0" Maximum="1" />
													<Button Grid.Column="3" Classes="icon-btn"
													        Command="{Binding $parent[ItemsControl].((vm:HapticsViewModel)DataContext).RemovePointCommand}"
													        CommandParameter="{Binding}"
													        ToolTip.Tip="Delete point">
														<lucide:LucideIcon Kind="X" Size="13" StrokeWidth="2.5"
														                   Foreground="{StaticResource TextMuted}" />
													</Button>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</StackPanel>
					</ScrollViewer>
				</DockPanel>
			</Border>

			<!-- Splitter -->
			<GridSplitter Grid.Column="1" ResizeDirection="Columns"
			              Background="Transparent" Width="4" />

			<!-- Canvas + legend -->
			<Panel Grid.Column="2">
				<cc:CurveCanvas Curves="{Binding CanvasItems}"
				                ActiveCurveIndex="{Binding ActiveCurveIndex}"
				                SelectedPointIndex="{Binding SelectedPointIndex, Mode=TwoWay}"
				                IsReadOnly="{Binding CanvasReadOnly}"
				                XMin="0" XMax="1" YMin="0" YMax="1" />

				<!-- Legend -->
				<ItemsControl ItemsSource="{Binding CanvasItems}"
				              HorizontalAlignment="Right" VerticalAlignment="Bottom"
				              Margin="0,0,16,30">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="12" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="cc:CurveCanvasItem">
							<StackPanel Orientation="Horizontal" Spacing="5">
								<Ellipse Width="8" Height="8" Fill="{Binding ColorBrush}"
								         VerticalAlignment="Center" />
								<TextBlock Text="{Binding Label}" FontSize="12"
								           Foreground="{StaticResource TextMuted}" />
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Panel>
		</Grid>

		<!-- Empty state -->
		<StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center"
		            IsVisible="{Binding !HasContent}">
			<lucide:LucideIcon Kind="Vibrate" Size="40" StrokeWidth="1.5"
			                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
			<TextBlock Text="No haptic open" FontWeight="SemiBold" FontSize="16"
			           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
			<TextBlock Text="Double-click a .thaptic asset in the Asset Browser"
			           FontStyle="Italic" Foreground="{StaticResource TextMuted}"
			           HorizontalAlignment="Center" />
		</StackPanel>
	</Panel>
</UserControl>
