<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:editor.Editors"
             xmlns:elements="using:editor.Components.Elements"
             xmlns:cc="using:editor.Components.CurveCanvas"
             xmlns:lucide="using:Lucide.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1800"
             d:DesignHeight="400"
             x:Class="editor.Editors.CurveView"
             x:DataType="vm:CurveViewModel"
             Background="{StaticResource Bg2}"
             Padding="8">

	<UserControl.KeyBindings>
		<KeyBinding Gesture="Ctrl+S"
		            Command="{Binding SaveCommand}" />
	</UserControl.KeyBindings>

	<UserControl.Styles>
		<Style Selector="TextBlock.lbl">
			<Setter Property="Foreground"
			        Value="{StaticResource TextMuted}" />
			<Setter Property="VerticalAlignment"
			        Value="Center" />
			<Setter Property="TextTrimming"
			        Value="CharacterEllipsis" />
		</Style>
		<Style Selector="Button.add-btn">
			<Setter Property="HorizontalAlignment"
			        Value="Stretch" />
			<Setter Property="HorizontalContentAlignment"
			        Value="Center" />
			<Setter Property="BorderThickness"
			        Value="0" />
			<Setter Property="Padding"
			        Value="6" />
			<Setter Property="CornerRadius"
			        Value="6" />
			<Setter Property="Cursor"
			        Value="Hand" />
		</Style>
		<Style Selector="Button.add-btn /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background"
			        Value="#303030" />
		</Style>
		<Style Selector="Button.add-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background"
			        Value="#404040" />
		</Style>
		<Style Selector="Button.icon-btn">
			<Setter Property="BorderThickness"
			        Value="0" />
			<Setter Property="Padding"
			        Value="5" />
			<Setter Property="CornerRadius"
			        Value="6" />
			<Setter Property="Cursor"
			        Value="Hand" />
			<Setter Property="Background"
			        Value="Transparent" />
			<Setter Property="VerticalAlignment"
			        Value="Center" />
		</Style>
		<Style Selector="Border.point-row">
			<Setter Property="CornerRadius"
			        Value="6" />
			<Setter Property="Padding"
			        Value="4" />
			<Setter Property="Background"
			        Value="Transparent" />
		</Style>
		<Style Selector="Border.point-row.selected">
			<Setter Property="Background"
			        Value="{StaticResource Bg4}" />
		</Style>
	</UserControl.Styles>

	<Design.DataContext>
		<vm:CurveViewModel />
	</Design.DataContext>

	<Panel>

		<!-- Editor -->
		<Grid ColumnDefinitions="260,8,*"
		      IsVisible="{Binding HasContent}">

			<!-- Left panel -->
			<Border Grid.Column="0"
			        Background="{StaticResource Bg3}"
			        CornerRadius="8"
			        Padding="8">
				<DockPanel VerticalSpacing="8">

					<!-- Header -->
					<DockPanel DockPanel.Dock="Top">
						<Button DockPanel.Dock="Right"
						        Classes="icon-btn"
						        Command="{Binding SaveCommand}"
						        Background="{StaticResource Red}"
						        ToolTip.Tip="Save (Ctrl+S)">
							<lucide:LucideIcon Kind="Save"
							                   Size="16"
							                   StrokeWidth="2.5" />
						</Button>
						<StackPanel Orientation="Horizontal"
						            Spacing="8"
						            VerticalAlignment="Center">
							<lucide:LucideIcon Kind="Spline"
							                   Size="16"
							                   StrokeWidth="2.5"
							                   Foreground="{StaticResource TextMuted}" />
							<TextBlock Text="{Binding DisplayTitle}"
							           FontWeight="Bold"
							           VerticalAlignment="Center"
							           TextTrimming="CharacterEllipsis" />
						</StackPanel>
					</DockPanel>

					<!-- Read-only banner -->
					<Border DockPanel.Dock="Top"
					        Background="{StaticResource DarkYellow}"
					        CornerRadius="6"
					        Padding="8,6"
					        IsVisible="{Binding IsReadOnly}">
						<StackPanel Orientation="Horizontal"
						            Spacing="6">
							<lucide:LucideIcon Kind="Lock"
							                   Size="13"
							                   StrokeWidth="2.5" />
							<TextBlock Text="3D curve — read-only"
							           FontSize="13"
							           VerticalAlignment="Center" />
						</StackPanel>
					</Border>

					<!-- Curve properties -->
					<Grid DockPanel.Dock="Top"
					      ColumnDefinitions="80,*"
					      RowDefinitions="Auto,Auto"
					      RowSpacing="6"
					      ColumnSpacing="8"
					      IsEnabled="{Binding !IsReadOnly}">
						<TextBlock Classes="lbl"
						           Text="Spline" />
						<elements:EnumBox Grid.Column="1"
						                  Value="{Binding SplineTypeName, Mode=TwoWay}"
						                  Options="{x:Static vm:CurveViewModel.SplineTypeNames}" />
						<TextBlock Grid.Row="1"
						           Classes="lbl"
						           Text="T Scale" />
						<elements:DragFloatBox Grid.Row="1"
						                       Grid.Column="1"
						                       Value="{Binding TScale, Mode=TwoWay}"
						                       Minimum="0.0001" />
					</Grid>

					<!-- Bezier hint -->
					<TextBlock DockPanel.Dock="Top"
					           Classes="lbl"
					           Text="{Binding BezierHint}"
					           FontSize="12"
					           TextWrapping="Wrap"
					           IsVisible="{Binding HasBezierHint}" />

					<!-- Points header -->
					<DockPanel DockPanel.Dock="Top">
						<Button DockPanel.Dock="Right"
						        Classes="icon-btn"
						        Command="{Binding AddPointCommand}"
						        IsEnabled="{Binding !IsReadOnly}"
						        ToolTip.Tip="Add point">
							<lucide:LucideIcon Kind="Plus"
							                   Size="14"
							                   StrokeWidth="2.5"
							                   Foreground="{StaticResource TextMuted}" />
						</Button>
						<TextBlock Text="Points"
						           FontWeight="SemiBold"
						           VerticalAlignment="Center" />
					</DockPanel>

					<!-- Point list -->
					<ScrollViewer HorizontalScrollBarVisibility="Disabled">
						<ItemsControl ItemsSource="{Binding PointRows}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Spacing="2" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:CurvePointVM">
									<Border Classes="point-row"
									        Classes.selected="{Binding IsSelected}">
										<Grid ColumnDefinitions="24,*,*,30"
										      ColumnSpacing="4"
										      IsEnabled="{Binding $parent[ItemsControl].((vm:CurveViewModel)DataContext).IsReadOnly, Converter={x:Static BoolConverters.Not}}">
											<TextBlock Classes="lbl"
											           Text="{Binding Label}"
											           FontSize="12"
											           HorizontalAlignment="Center" />
											<elements:DragFloatBox Grid.Column="1"
											                       Value="{Binding X, Mode=TwoWay}" />
											<elements:DragFloatBox Grid.Column="2"
											                       Value="{Binding Y, Mode=TwoWay}" />
											<Button Grid.Column="3"
											        Classes="icon-btn"
											        Command="{Binding $parent[ItemsControl].((vm:CurveViewModel)DataContext).RemovePointCommand}"
											        CommandParameter="{Binding}"
											        ToolTip.Tip="Delete point">
												<lucide:LucideIcon Kind="X"
												                   Size="13"
												                   StrokeWidth="2.5"
												                   Foreground="{StaticResource TextMuted}" />
											</Button>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</DockPanel>
			</Border>

			<!-- Splitter -->
			<GridSplitter Grid.Column="1"
			              ResizeDirection="Columns"
			              Background="Transparent"
			              Width="4" />

			<!-- Canvas -->
			<cc:CurveCanvas Grid.Column="2"
			                Curves="{Binding CanvasItems}"
			                SelectedPointIndex="{Binding SelectedPointIndex, Mode=TwoWay}"
			                IsReadOnly="{Binding IsReadOnly}" />
		</Grid>

		<!-- Empty state -->
		<StackPanel Spacing="8"
		            HorizontalAlignment="Center"
		            VerticalAlignment="Center"
		            IsVisible="{Binding !HasContent}">
			<lucide:LucideIcon Kind="Spline"
			                   Size="40"
			                   StrokeWidth="1.5"
			                   Foreground="{StaticResource TextMuted}"
			                   HorizontalAlignment="Center" />
			<TextBlock Text="No curve open"
			           FontWeight="SemiBold"
			           FontSize="16"
			           Foreground="{StaticResource TextMuted}"
			           HorizontalAlignment="Center" />
			<TextBlock Text="Double-click a .tcurve asset in the Asset Browser"
			           FontStyle="Italic"
			           Foreground="{StaticResource TextMuted}"
			           HorizontalAlignment="Center" />
		</StackPanel>
	</Panel>
</UserControl>