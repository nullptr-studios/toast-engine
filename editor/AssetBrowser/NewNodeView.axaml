<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        Width="500" Height="600" CanResize="False"
        CanMaximize="False" CanMinimize="False"
        WindowStartupLocation="CenterOwner"
        x:Class="editor.AssetBrowser.NewNodeView"
        Title="Select Node type..."
        Background="#202020"
        Padding="8">

	<DockPanel VerticalSpacing="8">
		<StackPanel DockPanel.Dock="Bottom" FlowDirection="RightToLeft" Orientation="Horizontal" Spacing="8">
			<Button Content="Create" Click="OnCreate"/>
			<Button Content="Cancel" Click="OnCancel"/>
		</StackPanel>
		<Border Background="#101010" CornerRadius="8" Padding="8">
			<DockPanel VerticalSpacing="8">
				<TextBox x:Name="SearchBox" DockPanel.Dock="Bottom" PlaceholderText="Search..." TextChanged="OnSearchChanged"/>
				<ScrollViewer>
					<TreeView x:Name="NodeTree" SelectionChanged="OnSelectionChanged">
						<TreeView.Styles>
							<Style Selector="TreeViewItem">
								<Setter Property="IsExpanded" Value="True"/>
							</Style>
						</TreeView.Styles>
						<TreeView.ItemTemplate>
							<TreeDataTemplate x:CompileBindings="False" ItemsSource="{Binding FilteredChildren}">
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
									<!-- TODO: load image from Icon attribute -->
									<Image Width="16" Height="16" VerticalAlignment="Center"/>
									<ItemsControl ItemsSource="{Binding Segments}"
									              Opacity="{Binding Opacity}"
									              FontStyle="{Binding FontStyle}"
									              Foreground="{Binding TextColor}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Orientation="Horizontal"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate x:CompileBindings="False">
												<TextBlock Text="{Binding Text}"
												           FontWeight="{Binding FontWeight}"
												           Background="{Binding Highlight}"/>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>
							</TreeDataTemplate>
						</TreeView.ItemTemplate>
					</TreeView>
				</ScrollViewer>
			</DockPanel>
		</Border>
	</DockPanel>
</Window>
