<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>player</AssemblyName>
    
    <!-- Disable auto-generated assembly info to avoid duplicates with xmake -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    
    <!-- Output to custom directory to not conflict with xmake build -->
    <BaseOutputPath>bin\</BaseOutputPath>
    <BaseIntermediateOutputPath>obj\</BaseIntermediateOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference the engine project - adjust path as needed -->
    <!-- <ProjectReference Include="..\..\engine\toast.engine.csproj" /> -->
    <!-- <ProjectReference Include="..\dummy_game\toast.dummy_game.csproj" /> -->
  </ItemGroup>

</Project>
