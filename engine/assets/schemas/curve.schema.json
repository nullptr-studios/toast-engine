{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "core://schemas/curve.schema.json",
  "title": "Toast Curve (.tcurve)",
  "type": "object",
  "required": ["spline_type", "dimension", "points"],
  "additionalProperties": false,
  "properties": {
    "spline_type": {
      "enum": ["linear", "catmull_rom", "bspline", "bezier"],
      "x-toast-type": "enum",
      "description": "linear: piecewise straight lines. catmull_rom: smooth interpolation through all points (automatic tangents). bspline: smooth cubic approximation (does not pass through interior points). bezier: compound cubic with explicit tangent handles; requires 3k+1 points."
    },
    "dimension": {
      "enum": ["2d", "3d"],
      "x-toast-type": "enum"
    },
    "t_scale": {
      "type": "number",
      "x-toast-type": "float",
      "default": 1.0,
      "exclusiveMinimum": 0
    },
    "points": {
      "type": "array",
      "x-toast-type": "point[]",
      "minItems": 2,
      "items": { "$ref": "#/definitions/point" }
    }
  },
  "definitions": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "x-toast-type": "float" },
        "y": { "type": "number", "x-toast-type": "float" },
        "z": { "type": "number", "x-toast-type": "float", "description": "Required when dimension is \"3d\"" }
      }
    }
  }
}
